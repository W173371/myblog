    <item>
      <title>几乎丧失了深度执行力</title>
      <link>http://localhost:1313/posts/2026-05-12-%E5%87%A0%E4%B9%8E%E4%B8%A7%E5%A4%B1%E4%BA%86%E6%B7%B1%E5%BA%A6%E6%89%A7%E8%A1%8C%E5%8A%9B/</link>
